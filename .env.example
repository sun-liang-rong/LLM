NODE_ENV=development
API_PORT=3000
WEB_PORT=5173

DATABASE_URL=file:../data/gateway.db
REDIS_URL=redis://localhost:6379

ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_JWT_SECRET=change-this-admin-jwt-secret
ADMIN_SESSION_TTL=86400
TENANT_JWT_SECRET=change-this-tenant-jwt-secret
TENANT_SESSION_TTL=86400
KEY_ENCRYPTION_SECRET=change-this-32-byte-minimum-secret
AUTH_LOGIN_LOCK_THRESHOLD=5
AUTH_LOGIN_LOCK_MINUTES=15
AUTH_LOGIN_IP_WINDOW_SECONDS=600
AUTH_LOGIN_IP_MAX_ATTEMPTS=10

# Public URLs
WEB_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# Verification code
AUTH_VERIFICATION_ENABLED=false
AUTH_VERIFICATION_CHANNEL=email
AUTH_VERIFICATION_CODE_LENGTH=6
AUTH_VERIFICATION_TTL=300
AUTH_VERIFICATION_RESEND_COOLDOWN=60
AUTH_VERIFICATION_MAX_ATTEMPTS=5
AUTH_VERIFICATION_DAILY_LIMIT=10
AUTH_VERIFICATION_DEV_CODE=123456

# Email verification sender / SMTP
AUTH_EMAIL_FROM_NAME=AI Gateway
AUTH_EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Comma separated provider keys. Add real values in .env, never commit them.
OPENAI_API_KEYS=
ANTHROPIC_API_KEYS=

# Default upstream endpoints.
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
