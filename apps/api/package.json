{
  "name": "@gateway/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm sqlite:init && nest start --watch",
    "start": "pnpm sqlite:init && node dist/main.js",
    "build": "nest build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/schema.prisma",
    "sqlite:init": "node scripts/init-sqlite.cjs"
  },
  "dependencies": {
    "@fastify/cors": "8.5.0",
    "@gateway/protocol": "workspace:*",
    "@gateway/shared": "workspace:*",
    "@nestjs/common": "10.3.10",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.3.10",
    "@nestjs/platform-fastify": "10.3.10",
    "@prisma/client": "5.16.2",
    "fastify": "4.28.0",
    "ioredis": "5.4.1",
    "nodemailer": "6.9.14",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "sqlite3": "5.1.7",
    "undici": "5.28.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.2",
    "@nestjs/schematics": "10.1.3",
    "@nestjs/testing": "10.3.10",
    "@types/node": "20.14.12",
    "@types/nodemailer": "6.4.15",
    "prisma": "5.16.2",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "typescript": "5.5.4"
  }
}
